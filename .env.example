PORT=4000

# Local: postgresql://postgres:postgres@localhost:5432/referral
# Live:  your Neon / production Postgres URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/referral

# test | live — switches EventHub API hosts (promo, events catalog)
EVENTHUB_API_ENV=test
EVENTHUB_DEFAULT_LANGUAGE=am

# Website API (events catalog)
# test: https://website.apitest.eventhub.am
# live: https://website.api.eventhub.am
EVENTHUB_API_BASE_URL=

# Promo API (secrets stay in env; discount rules are in CRM → Settings)
# test: https://promo.apitest.eventhub.am
# live: https://promo.api.eventhub.am
EVENTHUB_PROMO_API_BASE_URL=
EVENTHUB_PROMO_API_KEY=

# Dinno email API (API key stays in env; from/bcc/name are in CRM → Settings)
EMAIL_API_URL=https://email.dinno.am/api/send
EMAIL_API_KEY=

# Docker (Hostinger VPS):
#   docker compose up -d --build
# reads this file via env_file + volume mount (see docker-compose.yml).
# Plain docker run:
#   docker run -p 4000:4000 --env-file .env -v "$(pwd)/.env:/app/.env:ro" referal-server
